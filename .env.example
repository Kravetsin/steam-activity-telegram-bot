# Steam Web API key: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional: supergroup chat ID where the bot updates tags (if using a single chat)
TELEGRAM_CHAT_ID=

# Optional: interval in ms to poll Steam (default 60000 = 1 min)
POLL_INTERVAL_MS=60000